"0: " print 0 string cast print "\n" print
"1: " print 1 string cast print "\n" print

0
1

0
while dup 19 < {
  // n1 n2 i

  rot3

  // i n1 n2

  over
  over

  // i n1 n2 n1 n2
  +

  // i n1 n2 n3

  rot3 rot3

  // i n2 n3 n1

  drop

  // i n2 n3
  rot3 rot3
  dup 2 + string cast print ": " print
  rot3

  dup

  string cast print "\n" print

  rot3 rot3

  1 +
}
