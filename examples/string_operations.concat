"std:strings.concat" include

"1234" dup str_len swap
print ": " print print '\n' print

"Hello," " World!" assign str1 str2 {
  '"' print str1@ print '"' print
  " || " print
  '"' print str2@ print '"' print

  " = " print
  str1@ str2@ str_concat
  dup str_len
  swap
  '"' print print '"' print ": " print print '\n' print
}
