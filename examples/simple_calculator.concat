"std:strings.concat" include

func find_operation i32 i32 char*const -> void {
  @
  if dup '+' == {
    rot3 + print drop
  } else if dup '-' == {
    rot3 - print drop
  } else if dup '*' == {
    rot3 * print drop
  } else if dup '/' == {
    rot3 / print drop
  } else {
    drop drop drop
    "Unknown operation: Expected +-*/" print
  }

  '\n' print
}

"Value 1:   " print input str_to_i32
"Value 2:   " print input str_to_i32
"Operation: " print input "Output:    " print find_operation
